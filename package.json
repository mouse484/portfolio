    "eslint": "10.2.0",
    "eslint-plugin-format": "1.5.0",
    "eslint-plugin-svelte": "3.17.0",
    "stylelint": "17.7.0",
    "svelte": "5.55.4",
    "svelte-check": "4.4.6",
